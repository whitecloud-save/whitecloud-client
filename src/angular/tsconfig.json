{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../dist/angular",
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@electron/handler/main-handler/*": ["../../dist/types/electron/handler/main-handler/*"],
      "@electron/handler/worker-handler/*": ["../../dist/types/electron/handler/worker-handler/*"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "include": [
    "./**/*.ts"
  ],
  "exclude": [
    "./environments/environment.prod.ts"
  ]
}
